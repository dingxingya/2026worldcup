/* 2026世界杯 - 全局样式 */
page {
  background-color: #0f0f23;
  color: #e0e0e0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 主题色 */
:root {
  --primary: #4ecdc4;
  --secondary: #ff6b6b;
  --gold: #ffd93d;
  --bg-dark: #0f0f23;
  --bg-card: #1a1a2e;
  --bg-card-hover: #222240;
  --text-primary: #e0e0e0;
  --text-secondary: #888888;
  --border: #2a2a4a;
}

/* 通用容器 */
.container {
  padding: 24rpx;
}

/* 卡片 */
.card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.card-hover {
  background: var(--bg-card-hover);
}

/* 标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.tag-green {
  background: rgba(78, 205, 196, 0.2);
  color: var(--primary);
}

.tag-yellow {
  background: rgba(255, 217, 61, 0.2);
  color: var(--gold);
}

.tag-red {
  background: rgba(255, 107, 107, 0.2);
  color: var(--secondary);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 20rpx 0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: var(--text-secondary);
}
